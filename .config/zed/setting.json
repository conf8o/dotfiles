// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `zed: Open Default Settings` command
// from the command palette
{
  "cli_default_open_behavior": "new_window",
  "terminal": {
    "font_size": 15.0
  },
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "buffer_line_height": "comfortable",
  "agent_ui_font_size": 15.0,
  "agent_buffer_font_size": 15.0,
  "ui_font_family": "Moralerspace Neon HWNF",
  "buffer_font_family": "Moralerspace Neon HWNF",
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "icon_theme": "Catppuccin Mocha",
  "git_panel": {
    "dock": "left",
    "tree_view": true
  },
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "terminal": {
          "default": "confirm"
        },
        "copy_path": {
          "default": "confirm"
        },
        "move_path": {
          "default": "confirm"
        },
        "delete_path": {
          "default": "confirm"
        },
        "web_search": {
          "default": "allow"
        },
        "save_file": {
          "default": "allow"
        }
      }
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.2",
      "enable_thinking": false,
      "effort": "high"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "telemetry": {
    "metrics": false
  },
  "ui_font_size": 15.0,
  "buffer_font_size": 15.0,
  "theme": "One Dark",
  "languages": {
    "Elixir": {
      "enable_language_server": true,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "mix",
          "arguments": ["format", "--stdin-filename", "{buffer_path}", "-"]
        }
      },
      "language_servers": ["elixir-ls"]
    }
  },
  "lsp": {
    "elixir-ls": {
      "settings": {
        "dialyzerEnabled": false
      }
    }
  }
}
